# Backend Environment Variables
# Copy this file to .env and fill in the values

# MongoDB connection string (from MongoDB Atlas or local)
MONGODB_URI=mongodb://127.0.0.1:27017/marginalia

# JWT secrets — use long random strings (openssl rand -base64 64)
JWT_SECRET=your_super_secret_jwt_key_change_this
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_this

# Token expiry
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Frontend origin (for CORS — your Vercel URL, no trailing slash)
ALLOWED_ORIGIN=https://your-app.vercel.app

# Server port (Render sets PORT automatically)
PORT=5000

# Environment
NODE_ENV=production
